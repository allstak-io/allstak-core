{
  "name": "@allstak/core",
  "version": "0.1.1",
  "description": "AllStak core — transport, buffer, retry, event builder. Platform-agnostic foundation for @allstak/browser and @allstak/react-native.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abdualziz-urnt/allstak-core.git"
  },
  "homepage": "https://allstak.sa",
  "bugs": {
    "url": "https://github.com/abdualziz-urnt/allstak-core/issues"
  },
  "keywords": ["allstak", "observability", "sdk", "core"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap"
  },
  "dependencies": {
    "allstak-js": "^0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
